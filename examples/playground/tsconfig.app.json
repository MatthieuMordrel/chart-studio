{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@matthieumordrel/chart-studio": ["../../packages/chart-studio/src/index.ts"],
      "@matthieumordrel/chart-studio/_internal": ["../../packages/chart-studio/src/_internal.ts"],
      "@matthieumordrel/chart-studio-ui": ["../../packages/chart-studio-ui/src/index.ts"],
      "@matthieumordrel/chart-studio-devtools": ["../../packages/chart-studio-devtools/src/index.ts"],
      "@matthieumordrel/chart-studio-devtools/react": ["../../packages/chart-studio-devtools/src/react/index.ts"]
    }
  },
  "include": ["src"]
}
