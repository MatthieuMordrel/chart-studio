{
  "name": "@matthieumordrel/chart-studio",
  "version": "1.0.0",
  "description": "Headless, composable charting for React with an optional batteries-included UI layer.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatthieuMordrel/chart-studio.git"
  },
  "bugs": {
    "url": "https://github.com/MatthieuMordrel/chart-studio/issues"
  },
  "homepage": "https://github.com/MatthieuMordrel/chart-studio#readme",
  "author": "Matthieu Mordrel",
  "keywords": [
    "react",
    "charts",
    "recharts",
    "headless",
    "visualization",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:check": "bun run ./scripts/release-package.ts --dry-run",
    "release:publish": "bun run ./scripts/release-package.ts --publish"
  },
  "peerDependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.3",
    "recharts": "^2.15.4"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "lucide-react": "^0.577.0",
    "recharts": "^2.15.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "bun@1.3.9"
}
