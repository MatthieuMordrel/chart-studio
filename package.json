{
  "name": "@matthieumordrel/chart-studio",
  "version": "0.3.0",
  "description": "Headless, composable charting for React with an optional batteries-included UI layer.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.mts",
      "import": "./dist/ui/index.mjs"
    },
    "./ui/theme.css": "./dist/ui/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatthieuMordrel/chart-studio.git"
  },
  "bugs": {
    "url": "https://github.com/MatthieuMordrel/chart-studio/issues"
  },
  "homepage": "https://github.com/MatthieuMordrel/chart-studio#readme",
  "author": "Matthieu Mordrel",
  "license": "MIT",
  "keywords": [
    "react",
    "charts",
    "recharts",
    "headless",
    "visualization",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest run",
    "release": "bun run ./scripts/release-package.ts --bump",
    "release:check": "bun run ./scripts/release-package.ts --dry-run",
    "release:publish": "bun run ./scripts/release-package.ts --publish",
    "prepublishOnly": "bun run release:check"
  },
  "peerDependencies": {
    "lucide-react": ">=0.577.0 <1",
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20",
    "recharts": ">=3.0.0 <4"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.10"
}
